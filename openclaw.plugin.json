{
  "id": "openclaw-better-visual-gateway",
  "name": "Better Visual Gateway",
  "version": "0.1.0",
  "description": "Enhanced gateway UI with SWCUI embedding and theme alignment",
  "main": "dist/index.js",
  "configSchema": {
    "type": "object",
    "properties": {
      "swcui": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "Enable SWCUI embedding"
          },
          "mode": {
            "type": "string",
            "enum": ["local", "remote"],
            "default": "local",
            "description": "API proxy mode"
          },
          "localApiBaseUrl": {
            "type": "string",
            "default": "http://127.0.0.1:3001/api",
            "description": "Local API base URL"
          },
          "remoteApiBaseUrl": {
            "type": "string",
            "default": "",
            "description": "Remote API base URL"
          },
          "token": {
            "type": "string",
            "default": "",
            "description": "Optional token for x-claw-token header"
          },
          "dashboardUrl": {
            "type": "string",
            "default": "",
            "description": "Optional convenience link to dashboard"
          }
        },
        "default": {
          "enabled": true,
          "mode": "local",
          "localApiBaseUrl": "http://127.0.0.1:3001/api",
          "remoteApiBaseUrl": "",
          "token": "",
          "dashboardUrl": ""
        }
      },
      "reconnectIntervalMs": {
        "type": "number",
        "default": 3000,
        "description": "WebSocket reconnection interval in milliseconds"
      },
      "maxReconnectAttempts": {
        "type": "number",
        "default": 10,
        "description": "Maximum number of reconnection attempts before giving up"
      },
      "maxFileSize": {
        "type": "number",
        "default": 10485760,
        "description": "Maximum file size in bytes for File API operations (default: 10MB)"
      },
      "autoReconnectOnGap": {
        "type": "boolean",
        "default": true,
        "description": "Automatically reconnect when an event-gap message is detected"
      },
      "autoReconnectOnVisibility": {
        "type": "boolean",
        "default": true,
        "description": "Automatically reconnect when the tab becomes visible after being hidden"
      },
      "visibilityReconnectThresholdMs": {
        "type": "number",
        "default": 30000,
        "description": "How long the tab must be hidden (ms) before a visibility reconnect is triggered (default: 30s)"
      }
    },
    "required": []
  }
}
